{
    "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/master/assets/oh-my-openagent.schema.json",
    "agents": {
        "sisyphus": {
            "model": "bailian-coding-plan/kimi-k2.5"
        },
        "hephaestus": {
            "model": "github-copilot/gpt-5.3-codex",
            "variant": "medium"
        },
        "librarian": {
            "model": "bailian-coding-plan/MiniMax-M2.5"
        },
        "multimodal-looker": {
            "model": "github-copilot/gpt-5.4",
            "variant": "medium"
        },
        "prometheus": {
            "model": "github-copilot/gpt-5.4",
            "variant": "high"
